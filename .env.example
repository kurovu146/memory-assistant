# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789

# Claude API Keys (comma-separated for round-robin)
CLAUDE_API_KEYS=sk-ant-xxx

# Agent settings
MAX_AGENT_TURNS=30

# Voyage AI (optional - enables semantic search)
VOYAGE_API_KEY=pa-xxx
VOYAGE_MODEL=voyage-4-lite

# OpenAI (optional - enables GPT models)
# OPENAI_API_KEY=sk-xxx

# Gemini (optional - enables Gemini models via OpenAI-compat API)
# GEMINI_API_KEY=AIza-xxx

# Kimi (optional - enables Kimi K2.5 via Moonshot API)
# KIMI_API_KEY=sk-xxx

# Logging
RUST_LOG=info
